config box 'main'
	option enabled '1'
	option bin '/usr/bin/mihomo'
	option config '/etc/box/config.yaml'
	option workdir '/etc/box'
	option lan_if 'br-lan'
	option tproxy_port '9898'
	option dns_port '1053'
	option fwmark '1'
	option table '100'
	option routing_mark '255'
	option proxy_router_tcp '0'
	# Only LAN source IPs listed in this file are intercepted and sent to Mihomo.
	option lan_whitelist_file '/etc/box/lan_whitelist'
	option lan_whitelist_set 'box_lan_whitelist'
