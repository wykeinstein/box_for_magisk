#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

. /lib/functions.sh

BOX_BIN="/usr/bin/mihomo"
BOX_CONFIG="/etc/box/config.yaml"
BOX_WORKDIR="/etc/box"
BOX_ENABLED="1"

load_box_config() {
	config_load box
	config_get_bool BOX_ENABLED main enabled 1
	config_get BOX_BIN main bin "/usr/bin/mihomo"
	config_get BOX_CONFIG main config "/etc/box/config.yaml"
	config_get BOX_WORKDIR main workdir "/etc/box"
}

start_service() {
	load_box_config
	[ "$BOX_ENABLED" = "1" ] || return 0

	if [ ! -x "$BOX_BIN" ]; then
		echo "box: Mihomo binary not executable: $BOX_BIN" >&2
		return 1
	fi
	if [ ! -f "$BOX_CONFIG" ]; then
		echo "box: Mihomo config not found: $BOX_CONFIG" >&2
		return 1
	fi

	procd_open_instance box
	procd_set_param command "$BOX_BIN" -d "$BOX_WORKDIR" -f "$BOX_CONFIG"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	restart
}

service_triggers() {
	procd_add_reload_trigger box firewall network
}
